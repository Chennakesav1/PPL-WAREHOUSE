{
  "expo": {
    "name": "PPL Warehouse", 
    "slug": "ppl-warehouse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/download.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/download.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,

      "plugins": [
      [
        "expo-barcode-scanner",
        {
          "barcodeScannerPermission": "Allow the app to scan product barcodes."
        }
      ]
    ]
    },


    
    "android": {
      "adaptiveIcon": {
         "foregroundImage": "./assets/download.png",
        "backgroundColor": "#ffffff"
       
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-barcode-scanner"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}


